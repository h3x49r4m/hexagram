lay:inline-block; width:20px; height:20px; background:#14b8a6; border-radius:4px; vertical-align:middle;&#34;&gt;&lt;/span&gt;&lt;/td&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;td&gt;&lt;code&gt;#0d9488&lt;/code&gt; &lt;span style=&#34;display:inline-block; width:20px; height:20px; background:#0d9488; border-radius:4px; vertical-align:middle;&#34;&gt;&lt;/span&gt;&lt;/td&gt;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&lt;td&gt;&lt;code&gt;135deg, #2dd4bf, #0f766e&lt;/code&gt;&lt;/td&gt;&#xA;&#x9;&#x9;&#x9;&lt;/tr&gt;&#xA;&#x9;&lt;/tbody&gt;&#xA;&lt;/table&gt;</description>
